OLLAMA_BASE_URL=http://host.docker.internal:11434
FORCE_CPU=false
# Logs [LIVE_METRICS] RSS / RAM % / GPU VRAM / GPU util while a module holds GPU work (voice, document_translation, km_assistant)
GPU_LIVE_METRICS_ENABLED=true
# Sample interval seconds (ignored when nothing is active — sampling thread skips when refcounts are 0)
GPU_LIVE_METRICS_INTERVAL_SECONDS=3
