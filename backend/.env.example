OLLAMA_BASE_URL=http://host.docker.internal:11434
# Sent on every backend Ollama /api/chat as options.num_ctx (FastAPI/Docker env only; not systemd ollama.service).
# Lowers oversized server defaults that can crash ggml_cuda (e.g. INT_MAX assertion on load).
OLLAMA_NUM_CTX=32768
# Max simultaneous segment-translation batches; still parallel, bounded for stability alongside host OLLAMA_NUM_PARALLEL.
OLLAMA_TRANSLATE_MAX_PARALLEL=8
FORCE_CPU=false
# Logs [LIVE_METRICS] RSS / RAM % / GPU VRAM / GPU util while a module holds GPU work (voice, document_translation, km_assistant)
GPU_LIVE_METRICS_ENABLED=true
# Sample interval seconds (ignored when nothing is active — sampling thread skips when refcounts are 0)
GPU_LIVE_METRICS_INTERVAL_SECONDS=3

# STT: if first Whisper auto-detect is not zh/en/yue, transcribe a slice from offset (s) and
# re-run full file with fixed language when the sample is zh/en/yue (needs ffmpeg in container).
STT_LANG_RELISTEN_ENABLED=true
STT_LANG_RELISTEN_OFFSET_SEC=30
STT_LANG_RELISTEN_WINDOW_SEC=30
